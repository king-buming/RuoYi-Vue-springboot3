<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.system.mapper.TbWorkerCertMapper">

    <resultMap type="TbWorkerCert" id="TbWorkerCertResult">
        <result property="id"    column="id"    />
        <result property="workerId"    column="worker_id"    />
        <result property="certType"    column="cert_type"    />
        <result property="certNo"    column="cert_no"    />
        <result property="issueDate"    column="issue_date"    />
        <result property="expireDate"    column="expire_date"    />
        <result property="certImg"    column="cert_img"    />
        <result property="auditStatus"    column="audit_status"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="remark"    column="remark"    />
    </resultMap>

    <sql id="selectTbWorkerCertVo">
        select id, worker_id, cert_type, cert_no, issue_date, expire_date, cert_img, audit_status, create_by, create_time, update_by, update_time, remark from tb_worker_cert
    </sql>

    <select id="selectTbWorkerCertList" parameterType="TbWorkerCert" resultMap="TbWorkerCertResult">
        <include refid="selectTbWorkerCertVo"/>
        <where>
            <if test="workerId != null "> and worker_id = #{workerId}</if>
            <if test="certType != null  and certType != ''"> and cert_type = #{certType}</if>
            <if test="certNo != null  and certNo != ''"> and cert_no = #{certNo}</if>
            <if test="issueDate != null "> and issue_date = #{issueDate}</if>
            <if test="expireDate != null "> and expire_date = #{expireDate}</if>
            <if test="auditStatus != null  and auditStatus != ''"> and audit_status = #{auditStatus}</if>
        </where>
    </select>

    <select id="selectTbWorkerCertById" parameterType="Long" resultMap="TbWorkerCertResult">
        <include refid="selectTbWorkerCertVo"/>
        where id = #{id}
    </select>

    <insert id="insertTbWorkerCert" parameterType="TbWorkerCert" useGeneratedKeys="true" keyProperty="id">
        insert into tb_worker_cert
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="workerId != null">worker_id,</if>
            <if test="certType != null">cert_type,</if>
            <if test="certNo != null">cert_no,</if>
            <if test="issueDate != null">issue_date,</if>
            <if test="expireDate != null">expire_date,</if>
            <if test="certImg != null">cert_img,</if>
            <if test="auditStatus != null">audit_status,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="remark != null">remark,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="workerId != null">#{workerId},</if>
            <if test="certType != null">#{certType},</if>
            <if test="certNo != null">#{certNo},</if>
            <if test="issueDate != null">#{issueDate},</if>
            <if test="expireDate != null">#{expireDate},</if>
            <if test="certImg != null">#{certImg},</if>
            <if test="auditStatus != null">#{auditStatus},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="remark != null">#{remark},</if>
         </trim>
    </insert>

    <update id="updateTbWorkerCert" parameterType="TbWorkerCert">
        update tb_worker_cert
        <trim prefix="SET" suffixOverrides=",">
            <if test="workerId != null">worker_id = #{workerId},</if>
            <if test="certType != null">cert_type = #{certType},</if>
            <if test="certNo != null">cert_no = #{certNo},</if>
            <if test="issueDate != null">issue_date = #{issueDate},</if>
            <if test="expireDate != null">expire_date = #{expireDate},</if>
            <if test="certImg != null">cert_img = #{certImg},</if>
            <if test="auditStatus != null">audit_status = #{auditStatus},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="remark != null">remark = #{remark},</if>
        </trim>
        where id = #{id}
    </update>

    <delete id="deleteTbWorkerCertById" parameterType="Long">
        delete from tb_worker_cert where id = #{id}
    </delete>

    <delete id="deleteTbWorkerCertByIds" parameterType="String">
        delete from tb_worker_cert where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <delete id="deleteTbWorkerCertByWorkerId" parameterType="Long">
        delete from tb_worker_cert where worker_id = #{workerId}
    </delete>
</mapper>
